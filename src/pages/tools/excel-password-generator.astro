---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
---

<ToolLayout
  title="Excel向けパスワード生成 | 記号なしで安全なパスワード"
  description="Excelで使いやすい記号を含まない英数字のみのパスワードを生成。Excelファイルやスプレッドシートの管理に最適。大文字・小文字・数字のみで構成。"
  toolTitle="Excel向けパスワード生成"
  toolDescription="Excelやスプレッドシートで扱いやすい、記号を含まない英数字のみのパスワードを生成します。入力や管理が簡単で、業務利用に最適です。"
  canonical="https://www.pasuwadoseisei.com/tools/excel-password-generator"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'Excel向けパスワード生成'}]}
>
  <div slot="tool" class="excel-generator" id="excel-gen">
    <div class="result-box" id="excel-result">クリックして生成</div>
    <div class="options-grid">
      <label class="option-label">
        <span>文字数:</span>
        <select id="excel-length">
          <option value="8">8桁</option>
          <option value="10">10桁</option>
          <option value="12" selected>12桁</option>
          <option value="16">16桁</option>
        </select>
      </label>
      <label class="option-label">
        <input type="checkbox" id="excel-mixed" checked /> 大文字・小文字混在
      </label>
    </div>
    <div class="generator-actions">
      <button class="btn btn-primary btn-lg" id="excel-generate">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        生成
      </button>
      <button class="btn btn-secondary btn-lg" id="excel-copy">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        コピー
      </button>
    </div>
  </div>
  <section slot="content">
    <h2>Excel向けパスワードについて</h2>
    <p>Excelでパスワードを管理する際、記号が含まれているとCSV出力時に問題が発生したり、関数で扱いにくいことがあります。このツールでは英数字のみのパスワードを生成するため、Excelでの管理に最適です。</p>

    <h3>こんな方におすすめ</h3>
    <ul>
      <li>Excelでパスワード一覧を管理している方</li>
      <li>CSVファイルでパスワードをエクスポートする必要がある方</li>
      <li>記号の入力が難しい環境でパスワードを使用する方</li>
    </ul>

    <RelatedTools />
  </section>
</ToolLayout>

<script>
(function() {
  const result = document.getElementById('excel-result');
  const generateBtn = document.getElementById('excel-generate');
  const copyBtn = document.getElementById('excel-copy');
  const lengthSelect = document.getElementById('excel-length');
  const mixedCheck = document.getElementById('excel-mixed');

  function generateExcelPW() {
    const length = parseInt(lengthSelect.value);
    const mixed = mixedCheck.checked;
    let chars = '0123456789';
    if (mixed) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';
    else chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    let pw = '';
    for (let i = 0; i < length; i++) {
      pw += chars[Math.floor(Math.random() * chars.length)];
    }
    return pw;
  }

  function updatePW() {
    result.textContent = generateExcelPW();
    result.classList.remove('copied');
  }

  function copyPW() {
    const text = result.textContent;
    if (!text || text === 'クリックして生成') return;
    navigator.clipboard.writeText(text).then(() => {
      result.classList.add('copied');
      const toast = document.getElementById('toast') || (() => {
        const t = document.createElement('div');
        t.id = 'toast';
        t.className = 'toast';
        document.body.appendChild(t);
        return t;
      })();
      toast.textContent = 'コピーしました！';
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2000);
    });
  }

  generateBtn.addEventListener('click', updatePW);
  copyBtn.addEventListener('click', copyPW);
  result.addEventListener('click', copyPW);
  lengthSelect.addEventListener('change', updatePW);
  mixedCheck.addEventListener('change', updatePW);
  updatePW();
})();
</script>

<style>
  .excel-generator { width: 100%; }
  .generator-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
  .result-box { cursor: pointer; }
  .result-box:hover { border-color: var(--primary); }
</style>
