---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
---

<ToolLayout
  title="一括パスワード生成 | 複数パスワードをまとめて無料作成"
  description="複数のパスワードを一度にまとめて生成。10個・50個・100個のパスワードを一括で作成。社内アカウントやテストデータ作成に最適。"
  toolTitle="一括パスワード生成"
  toolDescription="複数のパスワードを一度にまとめて生成します。社内のアカウント発行や、システムのテストデータ作成など、大量のパスワードが必要な場面で便利です。"
  canonical="https://www.pasuwadoseisei.com/tools/bulk-password-generator"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'一括パスワード生成'}]}
>
  <div slot="tool" class="bulk-generator" id="bulk-gen">
    <div class="options-grid">
      <label class="option-label">
        <span>パスワードの長さ:</span>
        <select id="bulk-length">
          <option value="8">8桁</option>
          <option value="10">10桁</option>
          <option value="12" selected>12桁</option>
          <option value="16">16桁</option>
        </select>
      </label>
      <label class="option-label">
        <span>生成数:</span>
        <select id="bulk-count">
          <option value="5">5個</option>
          <option value="10" selected>10個</option>
          <option value="20">20個</option>
          <option value="50">50個</option>
          <option value="100">100個</option>
        </select>
      </label>
    </div>
    <div class="generator-actions">
      <button class="btn btn-primary btn-lg" id="bulk-generate">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        一括生成
      </button>
      <button class="btn btn-secondary btn-lg" id="bulk-copy">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        全てコピー
      </button>
    </div>
    <div class="result-textarea" id="bulk-result"></div>
  </div>
  <section slot="content">
    <h2>一括パスワード生成の活用シーン</h2>
    <ul>
      <li>社員のアカウントを一括発行する際</li>
      <li>システムのテストデータを作成する際</li>
      <li>イベントやキャンペーンの一時アカウントを作成する際</li>
      <li>学校や塾で生徒のアカウントを管理する際</li>
    </ul>

    <h3>注意点</h3>
    <p>一括生成したパスワードはCSVやExcelなどで管理し、安全に保管してください。特に社内で使用する場合は、パスワード管理ポリシーに従って適切に運用しましょう。</p>

    <RelatedTools />
  </section>
</ToolLayout>

<script>
(function() {
  const result = document.getElementById('bulk-result');
  const generateBtn = document.getElementById('bulk-generate');
  const copyBtn = document.getElementById('bulk-copy');
  const lengthSelect = document.getElementById('bulk-length');
  const countSelect = document.getElementById('bulk-count');

  function generatePassword(length) {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
    let pw = '';
    for (let i = 0; i < length; i++) {
      pw += chars[Math.floor(Math.random() * chars.length)];
    }
    return pw;
  }

  function generateBulk() {
    const length = parseInt(lengthSelect.value);
    const count = parseInt(countSelect.value);
    const passwords = [];
    for (let i = 0; i < count; i++) {
      passwords.push(`${i + 1}. ${generatePassword(length)}`);
    }
    result.textContent = passwords.join('\n');
  }

  function copyBulk() {
    if (!result.textContent) return;
    navigator.clipboard.writeText(result.textContent).then(() => {
      const toast = document.getElementById('toast') || (() => {
        const t = document.createElement('div');
        t.id = 'toast';
        t.className = 'toast';
        document.body.appendChild(t);
        return t;
      })();
      toast.textContent = `コピーしました！（${countSelect.value}個）`;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2000);
    });
  }

  generateBtn.addEventListener('click', generateBulk);
  copyBtn.addEventListener('click', copyBulk);
  lengthSelect.addEventListener('change', generateBulk);
  countSelect.addEventListener('change', generateBulk);
  generateBulk();
})();
</script>

<style>
  .bulk-generator { width: 100%; }
  .generator-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
  .result-textarea {
    margin-top: 16px;
    background: var(--bg-alt);
    border: 2px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    line-height: 1.8;
    min-height: 200px;
    max-height: 400px;
    overflow-y: auto;
    white-space: pre;
    user-select: all;
  }
</style>
