---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
---

<ToolLayout
  title="覚えやすいパスワード生成 | 記憶しやすい安全なパスワード"
  description="覚えやすくて安全なパスワードを生成。単語を組み合わせたパスフレーズ方式で、記憶しやすくかつ推測されにくいパスワードを作成します。"
  toolTitle="覚えやすいパスワード生成"
  toolDescription="単語を組み合わせたパスフレーズ方式で、覚えやすくて安全なパスワードを生成します。文字列だけでなく意味のあるフレーズとして記憶できるので、パスワードマネージャーがなくても管理が簡単です。"
  canonical="https://www.pasuwadoseisei.com/tools/memorable-password-generator"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'覚えやすいパスワード生成'}]}
>
  <div slot="tool" class="memo-generator" id="memo-gen">
    <div class="result-box" id="memo-result">クリックして生成</div>
    <div class="options-grid">
      <label class="option-label">
        <span>単語数:</span>
        <select id="memo-words">
          <option value="3">3単語</option>
          <option value="4" selected>4単語</option>
          <option value="5">5単語</option>
        </select>
      </label>
      <label class="option-label">
        <input type="checkbox" id="memo-capitalize" checked /> 各単語を大文字で開始
      </label>
      <label class="option-label">
        <input type="checkbox" id="memo-digits" checked /> 数字を追加
      </label>
    </div>
    <div class="generator-actions">
      <button class="btn btn-primary btn-lg" id="memo-generate">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        パスワードを生成
      </button>
      <button class="btn btn-secondary btn-lg" id="memo-copy">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        コピー
      </button>
    </div>
  </div>
  <section slot="content">
    <h2>覚えやすいパスワードの仕組み</h2>
    <p>このツールは「パスフレーズ」方式を採用しています。パスフレーズとは、複数の単語を組み合わせてパスワードを作成する方法で、以下のメリットがあります：</p>
    <ul>
      <li><strong>記憶しやすい</strong>：意味のある単語の組み合わせなので、ランダム文字列より覚えやすい</li>
      <li><strong>安全</strong>：単語数が多ければ、短いランダムパスワードよりも強力</li>
      <li><strong>タイプしやすい</strong>：記号が少なく、入力ミスが減る</li>
    </ul>

    <h3>パスフレーズの例</h3>
    <p>「Correct-Horse-Battery-Staple」は、xkcdというWebコミックで紹介された有名なパスフレーズの例です。単語を組み合わせることで、覚えやすくかつ強力なパスワードになります。</p>

    <RelatedTools />
  </section>
</ToolLayout>

<script>
(function() {
  const words = [
    'Apple', 'Bridge', 'Cloud', 'Dragon', 'Eagle', 'Forest', 'Garden', 'Harbor',
    'Island', 'Jungle', 'Koala', 'Lantern', 'Mountain', 'Nature', 'Ocean', 'Phoenix',
    'Queen', 'Rainbow', 'Star', 'Thunder', 'Umbrella', 'Valley', 'Water', 'Yellow',
    'Autumn', 'Breeze', 'Canyon', 'Delta', 'Eclipse', 'Falcon', 'Glacier', 'Horizon',
    'Icicle', 'Jasmine', 'Knot', 'Lemon', 'Maple', 'Nebula', 'Orbit', 'Piano',
    'Quartz', 'Rocket', 'Saturn', 'Tornado', 'Unicorn', 'Violet', 'Waffle', 'Zenith',
    'Anchor', 'Blossom', 'Crystal', 'Dolphin', 'Ember', 'Flame', 'Garnet', 'Haven',
    'Ivory', 'Jade', 'Kite', 'Lily', 'Marble', 'Nickel', 'Opal', 'Pearl',
  ];

  const result = document.getElementById('memo-result');
  const generateBtn = document.getElementById('memo-generate');
  const copyBtn = document.getElementById('memo-copy');
  const wordsSelect = document.getElementById('memo-words');
  const capitalizeCheck = document.getElementById('memo-capitalize');
  const digitsCheck = document.getElementById('memo-digits');

  function generateMemorable() {
    const count = parseInt(wordsSelect.value);
    const capitalize = capitalizeCheck.checked;
    const addDigits = digitsCheck.checked;
    
    const selected = [];
    const available = [...words];
    for (let i = 0; i < count; i++) {
      const idx = Math.floor(Math.random() * available.length);
      let word = available[idx];
      if (!capitalize) word = word.toLowerCase();
      selected.push(word);
      available.splice(idx, 1);
    }

    let password = selected.join('-');
    if (addDigits) {
      password += Math.floor(Math.random() * 100).toString().padStart(2, '0');
    }
    return password;
  }

  function updateMemo() {
    result.textContent = generateMemorable();
    result.classList.remove('copied');
  }

  function copyMemo() {
    const text = result.textContent;
    if (!text || text === 'クリックして生成') return;
    navigator.clipboard.writeText(text).then(() => {
      result.classList.add('copied');
      const toast = document.getElementById('toast') || (() => {
        const t = document.createElement('div');
        t.id = 'toast';
        t.className = 'toast';
        document.body.appendChild(t);
        return t;
      })();
      toast.textContent = 'コピーしました！';
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2000);
    });
  }

  generateBtn.addEventListener('click', updateMemo);
  copyBtn.addEventListener('click', copyMemo);
  result.addEventListener('click', copyMemo);
  wordsSelect.addEventListener('change', updateMemo);
  capitalizeCheck.addEventListener('change', updateMemo);
  digitsCheck.addEventListener('change', updateMemo);
  updateMemo();
})();
</script>

<style>
  .memo-generator { width: 100%; }
  .generator-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
  .result-box { cursor: pointer; }
  .result-box:hover { border-color: var(--primary); }
</style>
