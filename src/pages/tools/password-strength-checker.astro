---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import RelatedTools from '../../components/RelatedTools.astro';
---

<BaseLayout
  title="パスワード強度チェッカー | パスワードの安全性を診断"
  description="パスワードの強度をリアルタイムにチェック。長さ、文字種、パターンを分析してセキュリティレベルを評価します。"
>
  <StructuredData type="softwareapp" data={{
    name: 'パスワード強度チェッカー',
    description: 'パスワードの強度をリアルタイムに分析・診断するツール',
    url: 'https://www.pasuwadoseisei.com/tools/password-strength-checker',
  }} />

  <section style="padding:24px 0 60px;">
    <div class="tool-header">
      <h1>パスワード強度チェッカー</h1>
      <p class="tool-desc">パスワードを入力すると、その強度をリアルタイムに分析・診断します。</p>
    </div>
    <div class="card">
      <div id="strength-tool">
        <div class="input-group">
          <input type="password" id="strength-input" class="strength-input" placeholder="チェックするパスワードを入力..." aria-label="パスワード入力" />
          <button class="btn btn-sm btn-ghost" id="strength-toggle" aria-label="パスワード表示切替">表示</button>
        </div>
        <div class="strength-meter" style="margin-top:20px;">
          <div class="strength-header">
            <span class="strength-score-label">強度スコア</span>
            <span class="strength-score" id="strength-score">0/100</span>
          </div>
          <div class="strength-bar">
            <div class="strength-fill" id="strength-fill" style="width:0%"></div>
          </div>
          <div class="strength-status" id="strength-status">パスワードを入力してください</div>
        </div>
        <div class="strength-criteria" id="strength-criteria" style="margin-top:20px;display:none;">
          <div class="criteria-grid">
            <div class="criterion" data-test="length"><span class="criterion-icon">○</span> 8文字以上</div>
            <div class="criterion" data-test="length12"><span class="criterion-icon">○</span> 12文字以上</div>
            <div class="criterion" data-test="upper"><span class="criterion-icon">○</span> 大文字を含む</div>
            <div class="criterion" data-test="lower"><span class="criterion-icon">○</span> 小文字を含む</div>
            <div class="criterion" data-test="digit"><span class="criterion-icon">○</span> 数字を含む</div>
            <div class="criterion" data-test="symbol"><span class="criterion-icon">○</span> 記号を含む</div>
          </div>
        </div>
      </div>
    </div>
    <RelatedTools />
  </section>
</BaseLayout>

<script>
(function() {
  const input = document.getElementById('strength-input');
  const score = document.getElementById('strength-score');
  const fill = document.getElementById('strength-fill');
  const status = document.getElementById('strength-status');
  const criteria = document.getElementById('strength-criteria');
  const toggle = document.getElementById('strength-toggle');

  function checkStrength(pw) {
    let s = 0;
    const checks = {};
    if (pw.length >= 8) { s += 15; checks.length = true; } else checks.length = false;
    if (pw.length >= 12) { s += 20; checks.length12 = true; } else checks.length12 = false;
    if (pw.length >= 16) s += 10;
    if (/[A-Z]/.test(pw)) { s += 15; checks.upper = true; } else checks.upper = false;
    if (/[a-z]/.test(pw)) { s += 10; checks.lower = true; } else checks.lower = false;
    if (/\d/.test(pw)) { s += 10; checks.digit = true; } else checks.digit = false;
    if (/[^a-zA-Z0-9]/.test(pw)) { s += 20; checks.symbol = true; } else checks.symbol = false;
    s = Math.min(100, s);
    return { score: s, checks };
  }

  function update() {
    const pw = input.value;
    if (!pw) {
      score.textContent = '0/100';
      fill.style.width = '0%';
      fill.className = 'strength-fill';
      status.textContent = 'パスワードを入力してください';
      criteria.style.display = 'none';
      return;
    }
    criteria.style.display = 'block';
    const { score: s, checks } = checkStrength(pw);
    score.textContent = s + '/100';
    fill.style.width = s + '%';
    let cls = 'strength-fill';
    let label = '';
    if (s < 25) { cls += ' weak'; label = '脆弱'; }
    else if (s < 50) { cls += ' fair'; label = 'やや弱い'; }
    else if (s < 75) { cls += ' good'; label = '良好'; }
    else { cls += ' strong'; label = '非常に強い'; }
    fill.className = cls;
    status.textContent = label;

    document.querySelectorAll('.criterion').forEach(el => {
      const key = el.dataset.test;
      const icon = el.querySelector('.criterion-icon');
      if (checks[key]) {
        el.style.color = 'var(--secondary)';
        icon.textContent = '●';
      } else {
        el.style.color = 'var(--text-tertiary)';
        icon.textContent = '○';
      }
    });
  }

  input.addEventListener('input', update);
  toggle?.addEventListener('click', function() {
    if (input.type === 'password') { input.type = 'text'; toggle.textContent = '隠す'; }
    else { input.type = 'password'; toggle.textContent = '表示'; }
  });
})();
</script>

<style>
  .tool-header { margin-bottom: 32px; }
  .tool-header h1 { font-size: 32px; font-weight: 900; margin-bottom: 12px; letter-spacing: -0.02em; }
  .tool-desc { color: var(--text-secondary); line-height: 1.7; font-size: 16px; max-width: 700px; }
  .input-group { display: flex; gap: 8px; align-items: center; }
  .strength-input {
    flex: 1;
    padding: 16px 20px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: 'Courier New', monospace;
    font-size: 18px;
    background: var(--bg);
    color: var(--text);
    transition: border-color var(--transition);
  }
  .strength-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-light); }
  .strength-meter { display: flex; flex-direction: column; gap: 8px; }
  .strength-header { display: flex; justify-content: space-between; align-items: center; }
  .strength-score-label { font-size: 14px; font-weight: 600; color: var(--text-secondary); }
  .strength-score { font-size: 24px; font-weight: 900; color: var(--primary); font-feature-settings: "tnum"; }
  .strength-bar { height: 12px; background: var(--border); border-radius: 6px; overflow: hidden; }
  .strength-fill { height: 100%; border-radius: 6px; transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s ease; }
  .strength-fill.weak { background: #ef4444; }
  .strength-fill.fair { background: #f59e0b; }
  .strength-fill.good { background: #3b82f6; }
  .strength-fill.strong { background: #10b981; }
  .strength-status { font-size: 14px; font-weight: 700; }
  .criteria-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 8px; }
  .criterion { font-size: 14px; display: flex; align-items: center; gap: 6px; transition: color var(--transition); }
  .criterion-icon { font-size: 10px; width: 12px; text-align: center; flex-shrink: 0; }

  @media (max-width: 768px) {
    .tool-header h1 { font-size: 24px; }
    .strength-input { font-size: 16px; }
  }
</style>
