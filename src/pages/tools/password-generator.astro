---
import ToolLayout from '../../layouts/ToolLayout.astro';
import PasswordGenerator from '../../components/PasswordGenerator.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const faqs = [
  { question: 'このパスワード生成ツールは無料で使えますか？', answer: 'はい、完全無料でご利用いただけます。登録やインストールは不要で、ブラウザさえあればすぐに使い始められます。' },
  { question: '生成されたパスワードは安全ですか？', answer: 'はい。当ツールはブラウザの暗号論的乱数生成API（Crypto.getRandomValues）を使用しており、すべての処理はお客様のブラウザ上で完結します。生成されたパスワードがサーバーに送信されることは一切ありません。' },
  { question: 'どのくらいの文字数が推奨されますか？', answer: '一般的なWebサービスでは8桁以上、重要なアカウント（メール・銀行・SNSなど）では12桁以上を推奨します。当サイトでは4桁〜64桁まで自由に設定できます。' },
  { question: 'パスワードに記号を含める必要がありますか？', answer: '記号を含めることでパスワードの強度が大幅に向上します。多くのWebサービスで記号の使用が推奨されており、当ツールでは記号のON/OFFを自由に切り替えられます。' },
  { question: '「紛らわしい文字を除外」とは何ですか？', answer: '数字の「0」と英大文字の「O」、英小文字の「l」と英大文字の「I」など、見た目が似ていて間違えやすい文字をパスワードから除外するオプションです。パスワードを手入力する際のミスを防げます。' },
];

const howto = {
  name: 'パスワード生成ツールの使い方',
  description: '安全なパスワードを生成するための手順',
  steps: [
    { name: '文字数を設定', text: 'スライダーを使ってパスワードの長さを調整します。セキュリティと使いやすさのバランスから、12桁を推奨します。' },
    { name: '文字種を選択', text: '大文字（A-Z）、小文字（a-z）、数字（0-9）、記号（!@#$%^&*）からパスワードに含める文字の種類を選びます。' },
    { name: 'パスワードを生成', text: '「パスワードを生成」ボタンをクリックすると、選択した条件に基づいて安全なパスワードが自動的に作成されます。' },
    { name: 'コピーして使用', text: '生成されたパスワードをクリックするか「コピー」ボタンでクリップボードに保存し、各サービスの設定画面で使用します。' },
  ],
};
---

<ToolLayout
  title="パスワード生成 | 安全なパスワードを無料で自動生成"
  description="パスワード生成ツール。大文字・小文字・数字・記号を自由に組み合わせて、安全で強力なパスワードを無料で自動生成します。4〜64桁まで自由設定、ブラウザ完結で安全。"
  toolTitle="パスワード生成ツール"
  toolDescription="文字数や使用する文字の種類を細かく設定して、安全なパスワードを生成できます。推測されやすい単語や生年月日ではなく、ランダムな文字列でアカウントを保護しましょう。すべての処理はブラウザ上で完結し、パスワードがサーバーに送信されることはありません。"
  canonical="https://www.pasuwadoseisei.com/tools/password-generator"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'パスワード生成'}]}
  {faqs}
  howto={howto}
>
  <PasswordGenerator slot="tool" defaultLength={12} id="pwgen-main" />
  <section slot="content">
    <h2>パスワード生成ツールの特長</h2>
    <ul>
      <li><strong>カスタマイズ可能な文字数</strong>：4桁から64桁まで自由に設定</li>
      <li><strong>文字種の選択</strong>：大文字・小文字・数字・記号を個別にON/OFF</li>
      <li><strong>パスワード強度表示</strong>：生成されたパスワードの強度をリアルタイムに表示</li>
      <li><strong>紛らわしい文字を除外</strong>：「0」「O」「l」「I」などの見間違えやすい文字を除外可能</li>
      <li><strong>ブラウザ完結</strong>：すべての処理はブラウザ上で行われ、パスワードが外部に送信されることはありません</li>
    </ul>

    <h2>安全なパスワードの条件</h2>
    <p>安全なパスワードを作成するためには、以下の条件を満たすことが推奨されています：</p>
    <ul>
      <li><strong>12桁以上の長さ</strong>：短いパスワードは総当たり攻撃で簡単に突破されます</li>
      <li><strong>大文字・小文字・数字・記号の混在</strong>：異なる種類の文字を使うことで複雑性が向上</li>
      <li><strong>個人情報を使用しない</strong>：誕生日、名前、電話番号などは推測されやすい</li>
      <li><strong>使い回しをしない</strong>：サービスごとに異なるパスワードを使用しましょう</li>
    </ul>

    <h2>パスワードの管理方法</h2>
    <p>生成した複雑なパスワードを覚えるのは難しいため、パスワードマネージャーの利用をおすすめします：</p>
    <ul>
      <li><strong>Bitwarden</strong>：オープンソース、無料プランあり、全プラットフォーム対応</li>
      <li><strong>1Password</strong>：高機能、家族での共有が便利</li>
      <li><strong>KeePass</strong>：完全無料のオープンソース、ローカル保存</li>
      <li><strong>Googleパスワードマネージャー</strong>：Chrome標準、操作が簡単</li>
    </ul>

    <h2>パスワードの強度について</h2>
    <p>パスワードの強度は「長さ」と「文字の種類」の2要素で決まります。文字の種類を増やすよりも、パスワードを長くする方が効果的に強度を高められます。例えば、8桁のパスワードに記号を追加するよりも、12桁の英数字パスワードの方が一般的に安全です。</p>

    <section class="faq-section" aria-label="よくある質問">
      <h2>よくある質問</h2>
      {faqs.map(faq => (
        <details class="faq-item">
          <summary class="faq-question">{faq.question}</summary>
          <div class="faq-answer">{faq.answer}</div>
        </details>
      ))}
    </section>

    <RelatedTools />
  </section>
</ToolLayout>
