---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
---

<ToolLayout
  title="ハッシュ生成 | MD5/SHA1/SHA256/SHA512 オンライン計算"
  description="MD5、SHA-1、SHA-256、SHA-512のハッシュ値をリアルタイム計算。テキストのハッシュ値をブラウザ上で安全に生成。"
  toolTitle="ハッシュ生成 (MD5 / SHA-1 / SHA-256 / SHA-512)"
  toolDescription="入力テキストから各種ハッシュ値を生成します。MD5、SHA-1、SHA-256、SHA-512に対応。すべてブラウザ上で処理。"
  canonical="https://www.pasuwadoseisei.com/tools/hash-generator"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'ハッシュ生成'}]}
>
  <div slot="tool" id="hash-tool">
    <div class="input-group">
      <textarea id="hash-input" class="counter-textarea" placeholder="ハッシュ値を計算するテキストを入力..." rows="4" aria-label="入力テキスト"></textarea>
    </div>
    <div class="hash-results" style="margin-top:16px;">
      <div class="hash-item"><div class="hash-label">MD5</div><div class="hash-value" id="hash-md5">-</div></div>
      <div class="hash-item"><div class="hash-label">SHA-1</div><div class="hash-value" id="hash-sha1">-</div></div>
      <div class="hash-item"><div class="hash-label">SHA-256</div><div class="hash-value" id="hash-sha256">-</div></div>
      <div class="hash-item"><div class="hash-label">SHA-512</div><div class="hash-value" id="hash-sha512">-</div></div>
    </div>
  </div>
  <section slot="content">
    <h2>ハッシュ関数とは</h2>
    <p>ハッシュ関数は、任意の長さのデータを固定長の値（ハッシュ値）に変換する関数です。不可逆的な変換であり、元のデータを復元できません。</p>
    <h3>各アルゴリズムの特徴</h3>
    <ul>
      <li><strong>MD5</strong>：128ビットのハッシュ値。高速だが衝突耐性が低く、セキュリティ用途には非推奨</li>
      <li><strong>SHA-1</strong>：160ビットのハッシュ値。MD5より安全だが、現在は非推奨</li>
      <li><strong>SHA-256</strong>：256ビットのハッシュ値。現在の標準的なセキュリティハッシュ</li>
      <li><strong>SHA-512</strong>：512ビットのハッシュ値。より強固なセキュリティが必要な場合に</li>
    </ul>
    <RelatedTools />
  </section>
</ToolLayout>

<script>
(function() {
  const input = document.getElementById('hash-input');
  if (!input) return;

  async function updateHashes() {
    const text = input.value;
    if (!text) {
      ['md5','sha1','sha256','sha512'].forEach(id => {
        document.getElementById('hash-' + id).textContent = '-';
      });
      return;
    }
    const encoder = new TextEncoder();
    const data = encoder.encode(text);

    const md5Hash = await crypto.subtle.digest('MD5', data);
    const sha1Hash = await crypto.subtle.digest('SHA-1', data);
    const sha256Hash = await crypto.subtle.digest('SHA-256', data);
    const sha512Hash = await crypto.subtle.digest('SHA-512', data);

    document.getElementById('hash-md5').textContent = Array.from(new Uint8Array(md5Hash)).map(b => b.toString(16).padStart(2,'0')).join('');
    document.getElementById('hash-sha1').textContent = Array.from(new Uint8Array(sha1Hash)).map(b => b.toString(16).padStart(2,'0')).join('');
    document.getElementById('hash-sha256').textContent = Array.from(new Uint8Array(sha256Hash)).map(b => b.toString(16).padStart(2,'0')).join('');
    document.getElementById('hash-sha512').textContent = Array.from(new Uint8Array(sha512Hash)).map(b => b.toString(16).padStart(2,'0')).join('');
  }

  input.addEventListener('input', updateHashes);
})();
</script>

<style>
  .counter-textarea {
    width: 100%;
    padding: 14px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 15px;
    line-height: 1.6;
    resize: vertical;
    min-height: 100px;
    background: var(--bg);
    color: var(--text);
    transition: border-color var(--transition);
  }
  .counter-textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-light);
  }
  .counter-textarea::placeholder { color: var(--text-tertiary); }
  .input-group { display: flex; flex-direction: column; }
  .hash-results { display: flex; flex-direction: column; gap: 10px; }
  .hash-item {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
  }
  .hash-label { font-size: 12px; font-weight: 700; color: var(--text-tertiary); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
  .hash-value { font-family: 'Courier New', monospace; font-size: 14px; word-break: break-all; color: var(--text); line-height: 1.5; }
</style>
