---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
---

<ToolLayout
  title="全角半角変換ツール | 文字をワンクリックで変換"
  description="全角英数字・記号を半角に、または半角を全角に変換。カタカナの全角半角変換にも対応。日本語データ整理に必須のツール。"
  toolTitle="全角半角変換"
  toolDescription="全角文字と半角文字を相互変換します。英数字、記号、カタカナに対応。データ整理や入力値の正規化に便利です。"
  canonical="https://www.pasuwadoseisei.com/tools/zenkaku-hankaku"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'全角半角変換'}]}
>
  <div slot="tool" id="zenhan-tool">
    <textarea id="zenhan-input" class="counter-textarea" placeholder="変換したいテキストを入力..." rows="6" aria-label="変換するテキスト"></textarea>
    <div class="generator-actions" style="margin-top:16px;">
      <button class="btn btn-primary" id="zenhan-to-hankaku">半角に変換</button>
      <button class="btn btn-primary" id="zenhan-to-zenkaku">全角に変換</button>
      <button class="btn btn-secondary" id="zenhan-copy" style="margin-left:8px;">コピー</button>
    </div>
    <div class="result-box" id="zenhan-result" style="margin-top:16px;cursor:auto;user-select:all;">変換結果がここに表示されます</div>
  </div>
  <section slot="content">
    <h2>全角半角変換について</h2>
    <p>全角文字と半角文字の変換は、日本のシステム開発やデータ入力で頻繁に必要となる処理です。</p>
    <h3>変換対象</h3>
    <ul>
      <li>英字: 全角ＡＢＣ → 半角ABC / 半角abc → 全角ａｂｃ</li>
      <li>数字: 全角１２３ → 半角123</li>
      <li>記号: 全角！＠＃ → 半角!@#</li>
      <li>カタカナ: 半角ｶﾀｶﾅ → 全角カタカナ</li>
      <li>スペース: 全角スペース → 半角スペース</li>
    </ul>
    <RelatedTools />
  </section>
</ToolLayout>

<script>
(function() {
  const input = document.getElementById('zenhan-input');
  const result = document.getElementById('zenhan-result');
  if (!input || !result) return;

  const zenMap = 'ａｂｃｄｅｆｇｈｉｊｋｌｍｎｏｐｑｒｓｔｕｘｙｚｚＡＢＣＤＥＦＧＨＩＪＫＬＭＮＯＰＱＲＳＴＵＶＷＸＹＺ０１２３４５６７８９！＂＃＄％＆＇（）＊＋，－．／：；＜＝＞？＠［＼］＾＿｀｛｜｝～　';
  const hanMap = 'abcdefghijklmnopqrstuxyzzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!"#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~ ';

  const hanKanaMap = 'ｶﾞｷﾞｸﾞｹﾞｺﾞｻﾞｼﾞｽﾞｾﾞｿﾞﾀﾞﾁﾞﾂﾞﾃﾞﾄﾞﾊﾞﾋﾞﾌﾞﾍﾞﾎﾞﾊﾟﾋﾟﾌﾟﾍﾟﾎﾟｳﾞｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇﾈﾉﾊﾋﾌﾍﾎﾏﾐﾑﾒﾓﾔﾕﾖﾗﾘﾙﾚﾛﾜｦﾝｧｨｩｪｫｯｬｭｮ､｡｢｣･';
  const zenKanaMap = 'ガギグゲゴザジズゼゾダヂヅデドバビブベボパピプペポヴアイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲンァィゥェォッャュョ、。「」・';

  function toHankaku(text) {
    let r = '';
    for (const c of text) {
      const idx = zenMap.indexOf(c);
      if (idx >= 0) { r += hanMap[idx]; continue; }
      const ki = zenKanaMap.indexOf(c);
      if (ki >= 0) { r += hanKanaMap[ki]; continue; }
      r += c;
    }
    return r;
  }

  function toZenkaku(text) {
    let r = '';
    let i = 0;
    while (i < text.length) {
      let found = false;
      if (i + 1 < text.length) {
        const pair = text.substring(i, i + 2);
        const pi = hanKanaMap.indexOf(pair);
        if (pi >= 0) { r += zenKanaMap[pi]; i += 2; found = true; continue; }
      }
      const c = text[i];
      const idx = hanMap.indexOf(c);
      if (idx >= 0) { r += zenMap[idx]; }
      else {
        const ki = hanKanaMap.indexOf(c);
        if (ki >= 0) { r += zenKanaMap[ki]; }
        else { r += c; }
      }
      i += 1;
    }
    return r;
  }

  document.getElementById('zenhan-to-hankaku')?.addEventListener('click', function() {
    result.textContent = toHankaku(input.value) || '(空白)';
  });
  document.getElementById('zenhan-to-zenkaku')?.addEventListener('click', function() {
    result.textContent = toZenkaku(input.value) || '(空白)';
  });
  document.getElementById('zenhan-copy')?.addEventListener('click', function() {
    const text = result.textContent;
    if (text && text !== '変換結果がここに表示されます' && text !== '(空白)') {
      navigator.clipboard.writeText(text);
    }
  });
})();
</script>

<style>
  .counter-textarea {
    width: 100%;
    padding: 16px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 16px;
    line-height: 1.8;
    resize: vertical;
    min-height: 120px;
    background: var(--bg);
    color: var(--text);
    transition: border-color var(--transition);
  }
  .counter-textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-light);
  }
  .counter-textarea::placeholder { color: var(--text-tertiary); }
  .result-box { cursor: auto; user-select: all; }
</style>
