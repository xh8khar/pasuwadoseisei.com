---
import ToolLayout from '../../layouts/ToolLayout.astro';
import PasswordGenerator from '../../components/PasswordGenerator.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const faqs = [
  { question: 'ランダムパスワードと自分で考えたパスワード、どちらが安全ですか？', answer: 'ランダムパスワードの方が圧倒的に安全です。人間が考えるパスワードはどうしても「推測されやすいパターン」に偏ってしまうため、ランダム生成されたパスワードの方が総当たり攻撃や辞書攻撃に強いです。' },
  { question: 'ランダムパスワードの生成アルゴリズムは安全ですか？', answer: '当サイトではブラウザ標準の暗号論的乱数生成API（Crypto.getRandomValues）を使用しています。これはパスワード生成や暗号化など、セキュリティ業界で標準的に使用される安全なアルゴリズムです。' },
  { question: 'ランダムパスワードを覚える方法はありますか？', answer: 'ランダムパスワードを暗記するのは現実的ではありません。パスワードマネージャー（Bitwarden、1Passwordなど）を使用して安全に管理することを強くおすすめします。' },
];

const howto = {
  name: 'ランダムパスワード生成の使い方',
  description: '完全ランダムな安全なパスワードを生成する手順',
  steps: [
    { name: '文字数を設定', text: 'スライダーでパスワードの長さを調整します。14桁以上を推奨します。' },
    { name: '文字種を選択', text: '使用する文字の種類をチェックボックスで選択します。' },
    { name: '生成してコピー', text: '「生成」→「コピー」の順で使用します。' },
  ],
};
---

<ToolLayout
  title="ランダムパスワード生成 | 完全ランダムなパスワードを無料作成"
  description="完全ランダムなパスワードを無料で生成。Crypto.getRandomValues() による暗号論的に安全な乱数生成で、予測不可能な高セキュリティパスワードを自動生成します。ブラウザ完結。"
  toolTitle="ランダムパスワード生成"
  toolDescription="完全ランダムなパスワードを生成します。暗号論的に安全な乱数生成で、予測不可能な高セキュリティパスワードを作成します。パスワードマネージャーと併用することで、すべてのアカウントに強力なパスワードを設定できます。"
  canonical="https://www.pasuwadoseisei.com/tools/random-password-generator"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'ランダムパスワード生成'}]}
  {faqs}
  howto={howto}
>
  <PasswordGenerator slot="tool" defaultLength={14} id="pwgen-random" />
  <section slot="content">
    <h2>ランダムパスワードとは</h2>
    <p>ランダムパスワードとは、人間が意味を理解できないランダムな文字列で構成されたパスワードです。誕生日や名前、好きな言葉などと違い、第三者に推測されるリスクが極めて低くなります。</p>

    <h3>ランダムパスワードのメリット</h3>
    <ul>
      <li><strong>推測されにくい</strong>：個人情報や辞書単語を使わない</li>
      <li><strong>総当たり攻撃に強い</strong>：ランダム性が高いほど解読が困難</li>
      <li><strong>辞書攻撃を受けない</strong>：意味のある単語を含まない</li>
      <li><strong>サービスごとに異なるパスワードを簡単に作成できる</strong></li>
    </ul>

    <h3>乱数生成の品質について</h3>
    <p>当サイトのランダムパスワード生成は、ブラウザの <code>Crypto.getRandomValues()</code> メソッドを使用しています。これは暗号論的疑似乱数生成器（CSPRNG）であり、セキュリティ用途に適した品質の乱数を提供します。一般的な <code>Math.random()</code> よりもはるかに予測が困難です。</p>

    <section class="faq-section" aria-label="よくある質問">
      <h2>よくある質問</h2>
      {faqs.map(faq => (
        <details class="faq-item">
          <summary class="faq-question">{faq.question}</summary>
          <div class="faq-answer">{faq.answer}</div>
        </details>
      ))}
    </section>

    <RelatedTools />
  </section>
</ToolLayout>
