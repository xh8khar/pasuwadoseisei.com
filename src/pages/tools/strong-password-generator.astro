---
import ToolLayout from '../../layouts/ToolLayout.astro';
import PasswordGenerator from '../../components/PasswordGenerator.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const faqs = [
  { question: '「強力なパスワード」の定義は何ですか？', answer: '強力なパスワードとは、12桁以上の長さで、大文字・小文字・数字・記号の4種類すべてを含み、個人情報や辞書単語を使用していないパスワードを指します。当ツールではデフォルトで16桁の全文字種パスワードを生成します。' },
  { question: '最強のパスワードはどのようなものですか？', answer: '最強のパスワードは「16桁以上・大文字小文字数字記号を全て含む・完全ランダム」の条件を満たすものです。当サイトの強力なパスワード生成ツールで生成可能です。' },
  { question: '強力なパスワードを覚えられない場合はどうすればいいですか？', answer: '強力なパスワードを暗記する必要はありません。パスワードマネージャー（Bitwarden、1Password、KeePassなど）を使用して安全に管理することをおすすめします。マスターパスワードだけは確実に覚えてください。' },
];
---

<ToolLayout
  title="強力なパスワード生成 | 最強の安全パスワードを無料作成"
  description="大文字・小文字・数字・記号をすべて含む強力なパスワードを生成。16桁の最強レベルのパスワードを無料で自動生成。ブラウザ完結、サーバー送信なし。"
  toolTitle="強力なパスワード生成"
  toolDescription="大文字・小文字・数字・記号のすべてを含む、最強レベルのパスワードを生成します。最高のセキュリティが求められるアカウントに最適です。デフォルトは16桁。"
  canonical="https://www.pasuwadoseisei.com/tools/strong-password-generator"
  breadcrumbs={[{label:'TOP', href:'/'},{label:'ツール一覧', href:'/tools'},{label:'強力なパスワード生成'}]}
  {faqs}
>
  <PasswordGenerator slot="tool" defaultLength={16} id="pwgen-strong" />
  <section slot="content">
    <h2>強力なパスワードとは</h2>
    <p>強力なパスワードとは、以下の条件をすべて満たすパスワードを指します：</p>
    <ul>
      <li>12桁以上の長さがある</li>
      <li>大文字・小文字・数字・記号のすべてを含む</li>
      <li>辞書に載っている単語を含まない</li>
      <li>個人情報（誕生日、名前など）を使用していない</li>
      <li>過去に使用したパスワードと異なる</li>
    </ul>

    <h3>パスワード強度チェックリスト</h3>
    <ul>
      <li>□ 最低12桁以上あるか</li>
      <li>□ 4種類の文字種（大文字・小文字・数字・記号）をすべて含むか</li>
      <li>□ 意味のある単語やパターンを使っていないか</li>
      <li>□ 他のサービスと同じパスワードを使い回していないか</li>
      <li>□ パスワードマネージャーで管理しているか</li>
    </ul>

    <section class="faq-section" aria-label="よくある質問">
      <h2>よくある質問</h2>
      {faqs.map(faq => (
        <details class="faq-item">
          <summary class="faq-question">{faq.question}</summary>
          <div class="faq-answer">{faq.answer}</div>
        </details>
      ))}
    </section>

    <RelatedTools />
  </section>
</ToolLayout>
