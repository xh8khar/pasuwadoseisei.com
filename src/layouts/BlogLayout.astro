---
import BaseLayout from './BaseLayout.astro';
import StructuredData from '../components/StructuredData.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  category?: string;
  canonical?: string;
  breadcrumbs?: { label: string; href?: string }[];
  relatedPosts?: { title: string; href: string }[];
}

const {
  title, description, date, category, canonical, breadcrumbs, relatedPosts = [],
} = Astro.props;

const headings: { id: string; text: string; level: number }[] = [];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbs={breadcrumbs}
  datePublished={date}
  dateModified={date}
>
  <StructuredData
    type="article"
    data={{
      headline: title,
      description,
      datePublished: date,
      dateModified: date,
      url: canonical,
    }}
  />

  <article class="blog-article" itemscope itemtype="https://schema.org/Article">
    <meta itemprop="author" content="Yosin" />
    <meta itemprop="publisher" content="パスワード生成" />
    <link itemprop="mainEntityOfPage" href={canonical} />

    <header class="article-header">
      <h1 itemprop="headline">{title}</h1>
      <div class="meta">
        <time datetime={date} itemprop="datePublished">{date}</time>
        {category && <><span class="meta-sep">/</span><span itemprop="articleSection" class="tag">{category}</span></>}
        <span class="meta-sep">/</span>
        <span itemprop="author" itemscope itemtype="https://schema.org/Person">
          <span itemprop="name">Yosin</span>
        </span>
      </div>
    </header>

    <nav class="toc" aria-label="目次">
      <div class="toc-title">目次</div>
      <ol class="toc-list" id="toc-list"></ol>
    </nav>

    <div itemprop="articleBody" id="article-body">
      <slot />
    </div>

    <div class="share-buttons">
      <span class="share-label">シェア:</span>
      <a class="share-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonical || '')}`} target="_blank" rel="noopener noreferrer" aria-label="X（Twitter）でシェア">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X
      </a>
      <a class="share-btn" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonical || '')}`} target="_blank" rel="noopener noreferrer" aria-label="Facebookでシェア">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        Facebook
      </a>
      <a class="share-btn" href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(canonical || '')}`} target="_blank" rel="noopener noreferrer" aria-label="LINEでシェア">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.364 1.455H4.636A3.182 3.182 0 0 0 1.455 4.636v14.728a3.182 3.182 0 0 0 3.181 3.181h14.728a3.182 3.182 0 0 0 3.181-3.181V4.636a3.182 3.182 0 0 0-3.181-3.181z"/></svg>
        LINE
      </a>
    </div>

    <div class="author-card" itemprop="author" itemscope itemtype="https://schema.org/Person">
      <div class="author-avatar">Y</div>
      <div class="author-info">
        <h3 itemprop="name">Yosin</h3>
        <div class="author-role" itemprop="jobTitle">セキュリティブロガー・Web開発者</div>
        <p itemprop="description">パスワードセキュリティに関する情報を発信。当サイトの全ツール・全記事を執筆・開発。セキュリティとユーザビリティの両立を追求しています。<a href="/about">詳しいプロフィール →</a></p>
      </div>
    </div>

    {relatedPosts.length > 0 && (
      <section class="related-articles">
        <h2>関連記事</h2>
        <div class="blog-grid">
          {relatedPosts.map(post => (
            <a href={post.href} class="blog-card">
              <h3>{post.title}</h3>
              <span class="read-more">続きを読む →</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<script>
(function() {
  const body = document.getElementById('article-body');
  const tocList = document.getElementById('toc-list');
  if (!body || !tocList) return;

  const headings = body.querySelectorAll('h2, h3');
  headings.forEach((h, i) => {
    if (!h.id) {
      h.id = 'heading-' + i;
    }
    const li = document.createElement('li');
    li.className = h.tagName === 'H3' ? 'toc-h3' : 'toc-h2';
    const a = document.createElement('a');
    a.href = '#' + h.id;
    a.textContent = h.textContent;
    li.appendChild(a);
    tocList.appendChild(li);
  });

  if (headings.length === 0) {
    const toc = document.querySelector('.toc');
    if (toc) toc.style.display = 'none';
  }
})();
</script>

<style>
  .blog-article { padding: 24px 0 60px; }
  .article-header { margin-bottom: 36px; }
  .article-header h1 { font-size: clamp(26px, 4vw, 36px); font-weight: 900; letter-spacing: -0.02em; line-height: 1.25; margin-bottom: 16px; }
  .meta { font-size: 14px; color: var(--text-secondary); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .meta-sep { color: var(--text-tertiary); }
  .share-label { font-weight: 600; font-size: 14px; color: var(--text-secondary); padding: 8px 0; }

  @media (max-width: 768px) {
    .blog-article { padding: 16px 0 40px; }
  }
</style>
