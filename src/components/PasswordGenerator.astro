---
interface Props {
  defaultLength?: number;
  minLength?: number;
  maxLength?: number;
  showLengthControl?: boolean;
  showOptions?: boolean;
  showCopy?: boolean;
  showRegenerate?: boolean;
  showStrength?: boolean;
  label?: string;
  id?: string;
}

const {
  defaultLength = 12,
  minLength = 4,
  maxLength = 64,
  showLengthControl = true,
  showOptions = true,
  showCopy = true,
  showRegenerate = true,
  showStrength = true,
  label = '生成されたパスワード',
  id = 'pwg-' + Math.random().toString(36).slice(2, 8),
} = Astro.props;
---

<div class="password-generator" data-id={id} role="application" aria-label="パスワード生成ツール">
  <div class="result-box" id={`${id}-result`} role="textbox" aria-label="生成されたパスワード" tabindex={0}>
    <span class="result-text" id={`${id}-result-text`}>クリックして生成</span>
  </div>

  {showStrength && (
    <div class="strength-meter" role="status" aria-live="polite" aria-label="パスワード強度">
      <div class="strength-label-group">
        <span class="strength-label-text">パスワード強度</span>
        <span class="strength-label" id={`${id}-strength-label`}></span>
      </div>
      <div class="strength-bar" id={`${id}-strength-bar`}>
        <div class="strength-fill" id={`${id}-strength-fill`} style="width:0%"></div>
      </div>
    </div>
  )}

  <div class="generator-controls">
    {showLengthControl && (
      <div class="control-group">
        <div class="control-header">
          <label for={`${id}-length`}>文字数</label>
          <span class="length-value" id={`${id}-length-val`}>{defaultLength}</span>
        </div>
        <input type="range" id={`${id}-length`} min={minLength} max={maxLength} value={defaultLength}
          aria-valuemin={minLength} aria-valuemax={maxLength} aria-valuenow={defaultLength}
          oninput={`document.getElementById('${id}-length-val').textContent=this.value`} />
        <div class="range-labels">
          <span>{minLength}</span>
          <span>{maxLength}</span>
        </div>
      </div>
    )}

    {showOptions && (
      <fieldset class="options-grid">
        <legend class="sr-only">パスワードに含める文字の種類</legend>
        <label class="option-label">
          <input type="checkbox" id={`${id}-upper`} checked aria-checked="true" />
          <span class="option-check"></span>
          大文字 (A-Z)
        </label>
        <label class="option-label">
          <input type="checkbox" id={`${id}-lower`} checked aria-checked="true" />
          <span class="option-check"></span>
          小文字 (a-z)
        </label>
        <label class="option-label">
          <input type="checkbox" id={`${id}-numbers`} checked aria-checked="true" />
          <span class="option-check"></span>
          数字 (0-9)
        </label>
        <label class="option-label">
          <input type="checkbox" id={`${id}-symbols`} />
          <span class="option-check"></span>
          記号 (!@#$%^&*)
        </label>
        <label class="option-label">
          <input type="checkbox" id={`${id}-exclude-ambiguous`} />
          <span class="option-check"></span>
          紛らわしい文字を除外
        </label>
      </fieldset>
    )}

    <div class="generator-actions">
      {showRegenerate && (
        <button class="btn btn-primary btn-lg" id={`${id}-generate`} aria-label="パスワードを生成">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          パスワードを生成
        </button>
      )}
      {showCopy && (
        <button class="btn btn-secondary btn-lg" id={`${id}-copy`} aria-label="パスワードをコピー">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          コピー
        </button>
      )}
    </div>
  </div>
</div>

<div id="toast" class="toast" role="alert" aria-live="assertive"></div>

<script>
(function() {
  const container = document.currentScript?.closest?.('[data-id]') || document.querySelector('[data-id]');
  if (!container) return;
  const id = container.dataset.id;

  const result = document.getElementById(`${id}-result`);
  const resultText = document.getElementById(`${id}-result-text`);
  const generateBtn = document.getElementById(`${id}-generate`);
  const copyBtn = document.getElementById(`${id}-copy`);
  const lengthInput = document.getElementById(`${id}-length`);
  const upperCheck = document.getElementById(`${id}-upper`);
  const lowerCheck = document.getElementById(`${id}-lower`);
  const numbersCheck = document.getElementById(`${id}-numbers`);
  const symbolsCheck = document.getElementById(`${id}-symbols`);
  const excludeCheck = document.getElementById(`${id}-exclude-ambiguous`);
  const strengthFill = document.getElementById(`${id}-strength-fill`);
  const strengthLabel = document.getElementById(`${id}-strength-label`);
  const toast = document.getElementById('toast');

  let isGenerating = false;

  function generatePassword() {
    const length = lengthInput ? parseInt(lengthInput.value) : 12;
    const useUpper = upperCheck ? upperCheck.checked : true;
    const useLower = lowerCheck ? lowerCheck.checked : true;
    const useNumbers = numbersCheck ? numbersCheck.checked : true;
    const useSymbols = symbolsCheck ? symbolsCheck.checked : false;
    const excludeAmbiguous = excludeCheck ? excludeCheck.checked : false;

    let chars = '';
    if (useUpper) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    if (useLower) chars += 'abcdefghijklmnopqrstuvwxyz';
    if (useNumbers) chars += '0123456789';
    if (useSymbols) chars += '!@#$%^&*()_+-=[]{}|;:,.<>?';

    if (excludeAmbiguous) {
      chars = chars.replace(/[0OoIl1]/g, '');
    }

    if (!chars) {
      showToast('少なくとも1つの文字タイプを選択してください');
      return '';
    }

    let password = '';
    if (useUpper) password += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'[Math.floor(Math.random() * 26)];
    if (useLower) password += 'abcdefghijklmnopqrstuvwxyz'[Math.floor(Math.random() * 26)];
    if (useNumbers) password += '0123456789'[Math.floor(Math.random() * 10)];
    if (useSymbols) password += '!@#$%^&*()_+-=[]{}|;:,.<>?'[Math.floor(Math.random() * 24)];

    for (let i = password.length; i < length; i++) {
      password += chars[Math.floor(Math.random() * chars.length)];
    }

    password = password.split('').sort(() => Math.random() - 0.5).join('');
    return password;
  }

  function calculateStrength(pw) {
    let score = 0;
    if (pw.length >= 8) score += 25;
    if (pw.length >= 12) score += 25;
    if (pw.length >= 16) score += 25;
    if (/[a-z]/.test(pw) && /[A-Z]/.test(pw)) score += 25;
    if (/\d/.test(pw)) score += 15;
    if (/[^a-zA-Z0-9]/.test(pw)) score += 20;
    if (pw.length >= 20) score += 15;
    return Math.min(100, score);
  }

  function getStrengthLabel(score) {
    if (score < 25) return { text: '脆弱', class: 'weak' };
    if (score < 50) return { text: 'やや弱い', class: 'fair' };
    if (score < 75) return { text: '良好', class: 'good' };
    return { text: '非常に強い', class: 'strong' };
  }

  function updatePassword() {
    if (isGenerating) return;
    isGenerating = true;
    const pw = generatePassword();
    if (pw) {
      resultText.textContent = pw;
      result.classList.remove('copied');
      if (strengthFill && strengthLabel) {
        const score = calculateStrength(pw);
        const info = getStrengthLabel(score);
        strengthFill.style.width = score + '%';
        strengthFill.setAttribute('aria-valuenow', score);
        strengthLabel.textContent = info.text;
        strengthFill.className = 'strength-fill ' + info.class;
      }
    }
    isGenerating = false;
  }

  function copyPassword() {
    const text = resultText.textContent;
    if (!text || text === 'クリックして生成') return;
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(() => {
        result.classList.add('copied');
        setTimeout(function() { result.classList.remove('copied'); }, 700);
        showToast('クリップボードにコピーしました！');
      });
    } else {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      result.classList.add('copied');
      setTimeout(function() { result.classList.remove('copied'); }, 700);
      showToast('クリップボードにコピーしました！');
    }
  }

  function showToast(msg) {
    if (toast) {
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(function() { toast.classList.remove('show'); }, 2500);
    }
  }

  if (generateBtn) generateBtn.addEventListener('click', updatePassword);
  if (copyBtn) copyBtn.addEventListener('click', copyPassword);
  if (result) result.addEventListener('click', copyPassword);
  if (lengthInput) lengthInput.addEventListener('input', updatePassword);
  if (upperCheck) upperCheck.addEventListener('change', updatePassword);
  if (lowerCheck) lowerCheck.addEventListener('change', updatePassword);
  if (numbersCheck) numbersCheck.addEventListener('change', updatePassword);
  if (symbolsCheck) symbolsCheck.addEventListener('change', updatePassword);
  if (excludeCheck) excludeCheck.addEventListener('change', updatePassword);

  updatePassword();
})();
</script>

<style>
  .password-generator { width: 100%; }
  .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0; }
  .generator-controls { display: flex; flex-direction: column; gap: 24px; }
  .control-group { display: flex; flex-direction: column; gap: 8px; }
  .control-header { display: flex; justify-content: space-between; align-items: center; }
  .control-header label { font-size: 14px; font-weight: 600; color: var(--text); }
  .length-value {
    font-size: 20px;
    font-weight: 900;
    color: var(--primary);
    min-width: 32px;
    text-align: right;
    line-height: 1;
    font-feature-settings: "tnum";
  }
  .control-group input[type="range"] {
    width: 100%;
    height: 6px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--border);
    border-radius: 3px;
    outline: none;
    cursor: pointer;
  }
  .control-group input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--primary);
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(37,99,235,0.3);
    transition: box-shadow var(--transition);
    border: 3px solid white;
  }
  .control-group input[type="range"]::-webkit-slider-thumb:hover {
    box-shadow: 0 4px 12px rgba(37,99,235,0.4);
  }
  .control-group input[type="range"]::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--primary);
    cursor: pointer;
    border: 3px solid white;
    box-shadow: 0 2px 6px rgba(37,99,235,0.3);
  }
  .range-labels { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-tertiary); }
  .options-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin: 0; padding: 0; border: none; }
  .option-label { position: relative; display: flex; align-items: center; gap: 10px; font-size: 14px; cursor: pointer; padding: 12px 16px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); transition: all var(--transition); background: var(--bg); }
  .option-label:hover { border-color: var(--primary); background: var(--primary-bg); }
  .option-label:has(input:checked) { border-color: var(--primary); background: var(--primary-bg); }
  .option-label input[type="checkbox"] { position: absolute; opacity: 0; width: 0; height: 0; }
  .option-check {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border);
    border-radius: 5px;
    flex-shrink: 0;
    transition: all var(--transition);
    position: relative;
  }
  .option-check::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 6px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg) scale(0);
    transition: transform var(--transition);
  }
  .option-label:has(input:checked) .option-check {
    background: var(--primary);
    border-color: var(--primary);
  }
  .option-label:has(input:checked) .option-check::after {
    transform: rotate(45deg) scale(1);
  }
  .generator-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 4px; }
  .generator-actions .btn { gap: 8px; }
  .result-box { cursor: pointer; position: relative; overflow: hidden; user-select: all; transition: all var(--transition); }
  .result-box:hover { border-color: var(--primary); background: var(--primary-bg); }
  .result-box:focus-visible { outline: 2px solid var(--primary); outline-offset: 2px; }
  .result-text { position: relative; z-index: 1; }

  .strength-meter { display: flex; flex-direction: column; gap: 8px; margin: -4px 0 8px; }
  .strength-label-group { display: flex; justify-content: space-between; align-items: center; }
  .strength-label-text { font-size: 13px; font-weight: 600; color: var(--text-secondary); }
  .strength-label { font-size: 13px; font-weight: 700; }
  .strength-bar { height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
  .strength-fill { height: 100%; border-radius: 4px; transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s ease; }
  .strength-fill.weak { background: #ef4444; }
  .strength-fill.fair { background: #f59e0b; }
  .strength-fill.good { background: #3b82f6; }
  .strength-fill.strong { background: #10b981; }

  @media (max-width: 768px) {
    .options-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .options-grid { grid-template-columns: 1fr; }
  }
</style>
